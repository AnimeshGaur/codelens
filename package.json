{
    "name": "codelens",
    "version": "2.0.0",
    "description": "AI-powered codebase analyzer — paste GitHub links, get professional technical documentation with Mermaid diagrams.",
    "type": "module",
    "scripts": {
        "install:all": "npm install && cd client && npm install",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "server": "node server/index.js",
        "client": "npm run dev --prefix client",
        "build": "npm run build --prefix client",
        "start": "npm run build && node server/index.js",
        "postinstall": "cd client && npm install"
    },
    "keywords": [
        "codebase",
        "analyzer",
        "mermaid",
        "diagram",
        "architecture",
        "llm",
        "github"
    ],
    "license": "MIT",
    "dependencies": {
        "concurrently": "^9.1.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "ollama": "^0.5.0"
    }
}